     <form asp-action="CreateRequest" method="post" enctype="multipart/form-data">
            
            <!-- Page Header -->
            <h1 class="page-title">New Verification Request</h1>
            <p class="page-subtitle">Submit candidate details for background verification</p>

            <!-- 1. Candidate Information Section -->
            <div class="form-section">
                <h4 class="section-title mb-4">Candidate Information</h4>
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label">Full Name</label>
                        <input asp-for="Name" type="text" class="form-control" placeholder="">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="">
                    </div>
                  
                    <div class="col-md-6">
                        <label class="form-label">Phone Number</label>
                        <input asp-for="Mobile" type="tel" class="form-control" placeholder="">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Date of Birth</label>
                        <input asp-for="DOB" type="date" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Position Applied For</label>
                        <input asp-for="Position" type="text" class="form-control" placeholder="">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Department</label>
                        <input asp-for="Department" type="text" class="form-control" placeholder="">
                    </div>
                </div>
            </div>

            <!-- 2. Document Upload Section -->
            <div class="form-section">
                <h4 class="section-title">Document Upload</h4>
                <p class="section-subtitle">Upload candidate documents (Aadhar, PAN, certificates, etc.)</p>
                <label for="file-upload" class="upload-area w-100 d-block">
                    <i class="bi bi-upload upload-icon"></i>
                    <div class="upload-text">Click to upload or drag files here</div>
                    <div class="upload-subtext">PDF, JPG, PNG — Max 10MB each</div>

                    <!-- 👇 NEW -->
                    <div id="fileName" style="margin-top:10px; font-size:13px; color:#2563eb;"></div>

                    <input asp-for="DocumentPath" type="file" id="file-upload"
                           class="d-none" multiple accept=".pdf,.jpg,.jpeg,.png">
                </label>
            </div>

            <!-- 3. Verification Types Section -->
            <div class="form-section">
                <h4 class="section-title">Verification Types</h4>
                <p class="section-subtitle">Select the checks you need performed</p>
                <div class="row g-3">
                    @if (ViewBag.Data != null)
                    {
                        foreach (var row in ViewBag.Data)
                        {
                            <div class="col-12 col-md-6 col-lg-4">
                                <input name="VerifyTypes" type="checkbox"
                                       class="btn-check"
                                       value="@row.Id"
                                       id="check_@row.Id" autocomplete="off">

                                <label class="custom-select-card" for="check_@row.Id">
                                    <i class="bi bi-fingerprint"></i> @row.Name
                                </label>
                            </div>
                        }
                    }

                </div>
            </div>

            <!-- 4. Priority Section -->
            <div class="form-section mb-5">
                <h4 class="section-title mb-3">Priority</h4>
                <div class="d-flex gap-3">
                    <div>
                        <input asp-for="Priority" type="radio" class="btn-check" name="priority" value="Normal" id="priority-normal" checked>
                        <label class="custom-select-card priority-btn" for="priority-normal">
                            Normal
                        </label>
                    </div>
                    <div>
                        <input asp-for="Priority" type="radio" class="btn-check" name="priority" value="Urgent" id="priority-urgent">
                        <label class="custom-select-card priority-btn" for="priority-urgent">
                            Urgent
                        </label>
                    </div>
                </div>
            
                <!-- Action Buttons -->
                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-light border">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Submit Request</button>
                </div>
            </div>

     </form>
    </div>
</div>
<script>
    document.getElementById("file-upload").addEventListener("change", function () {
        let fileDisplay = document.getElementById("fileName");

        if (this.files.length > 0) {
            let names = [];

            for (let i = 0; i < this.files.length; i++) {
                names.push(this.files[i].name);
            }

            fileDisplay.innerHTML = "Selected: <br>" + names.join("<br>");
        } else {
            fileDisplay.innerHTML = "";
        }
    });



    $(document).ready(function () {
        $.ajax({
            url: '/Admin/GetData',
            type: 'GET',
            success: function (data) {
                // Clear old options
                $("#job").empty();

                // Add default option
                $("#job").append('<option value="">-- Select Emp --</option>');

                // Build options
                var row = '';
                $.each(data, function (i, e) {
                    row += `<option value="${e.employeeId}">${e.name}</option>`;
                });

                // Append to dropdown
                $("#job").append(row);
            },
            error: function (xhr, status, error) {
                alert("Error: " + error);
            }
        });

    })


    $(document).on("click", "#saveJobBtn", function () {

        var empid = $("#job").val();
        var companyId = $("#company").val();

        // Get clientId from URL
        var pathParts = window.location.pathname.split('/');
        var clientId = pathParts[pathParts.length - 1];

        if (!empid) {
            alert("Please select an employee..");
            return;
        }

        $.ajax({
            url: '/Admin/SaveEmpInClient',
            type: 'POST',
            data: { id: empid, clientId: clientId, companyId: companyId, },
            success: function (response) {
                if (response.success) {
                    alert(response.message);
                    location.href = '/Admin/Dashboard'
                } else {
                    alert(response.message);
                }
            },
            error: function (res) {
                alert("Server Error");
            }
        });
    });

</script>